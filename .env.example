# ── Hedera Operator ──────────────────────────────────────────────────────────
HEDERA_ACCOUNT_ID=              # e.g. 0.0.1234567
HEDERA_PRIVATE_KEY=             # DER-encoded private key (starts with 302e...)
HEDERA_NETWORK=testnet          # testnet | mainnet

# ── Nullum On-Chain Resources ─────────────────────────────────────────────────
# Leave blank on first run — Nullum will create these and print the IDs to console.
# Copy the printed values here and into your Netlify environment variables.
NULLUM_TREASURY_ACCOUNT_ID=     # A DIFFERENT account from HEDERA_ACCOUNT_ID (receives audit fees)
NULLUM_TOPIC_ID=                # HCS topic ID (auto-created on first run if blank)
NULLUM_NFT_TOKEN_ID=            # HTS NFT collection token ID (auto-created on first run if blank)

# ── LLM ──────────────────────────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com — no credit card required.
GOOGLE_API_KEY=

# ── Deployment ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=            # e.g. https://nullum.netlify.app
